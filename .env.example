# ==========================================
# ClipFlow Environment Configuration
# ==========================================
# Copy this file to .env and fill in your credentials

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DB_PATH=./db/clipflow.db

# File Storage Paths
UPLOADS_DIR=../uploads
GENERATED_DIR=../generated
THUMBNAILS_DIR=../thumbnails
LOGS_DIR=../logs

# ==========================================
# TikTok API (Official)
# Get from: https://developers.tiktok.com
# ==========================================
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ==========================================
# YouTube Data API v3
# Get from: https://console.cloud.google.com
# ==========================================
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3001/auth/youtube/callback

# ==========================================
# Instagram Graph API
# Get from: https://developers.facebook.com
# ==========================================
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:3001/auth/instagram/callback

# ==========================================
# Puppeteer Fallback (browser automation)
# Only used if official APIs fail
# ==========================================
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=60000

# ==========================================
# Video Processing
# ==========================================
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
VIDEO_SPEED=15
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920

# ==========================================
# Encryption (for storing credentials)
# Generate with: openssl rand -hex 32
# ==========================================
ENCRYPTION_KEY=your_32_char_encryption_key_here
